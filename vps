#!/bin/bash

# 自动修复 Windows 换行符问题
sed -i 's/\r$//' "$0" 2>/dev/null

# 定义颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 作者与脚本信息
AUTHOR_GITHUB="https://github.com/Taylor000"
SHORTCUT_CMD="vps"

# 默认全局配置
DEFAULT_PORT="11156"
DEFAULT_PASS="github.taylor000"

# 检查是否为 Root
[[ $EUID -ne 0 ]] && echo -e "${RED}错误：请使用 root 用户运行此脚本！${NC}" && exit 1

# 空输入计数器
empty_count=0

# 获取系统基本网络信息
get_network_info() {
    LOCAL_IP=$(curl -s https://api64.ipify.org)
    LOCAL_GATEWAY=$(ip route | grep default | awk '{print $3}' | head -n1)
    LOCAL_MASK="255.255.255.0"
}

# 菜单函数
show_menu() {
    clear
    echo -e "${BLUE}==================================================${NC}"
    echo -e "${GREEN}             VPS 综合管理工具箱                  ${NC}"
    echo -e "${BLUE}     Author: ${YELLOW}${AUTHOR_GITHUB}${NC}"
    echo -e "${BLUE}     快捷启动命令: ${RED}${SHORTCUT_CMD}${NC}"
    echo -e "${BLUE}==================================================${NC}"
    echo -e "${YELLOW} 1.${NC} 显示系统基本信息与性能测试"
    echo -e "${YELLOW} 2.${NC} 修改 SSH 服务端口 (当前默认: $DEFAULT_PORT)"
    echo -e "${YELLOW} 3.${NC} 安装 BBR 加速插件 (秋水逸冰)"
    echo -e "${YELLOW} 4.${NC} 安装 Debian 11 系统 (默认密码: $DEFAULT_PASS)"
    echo -e "${YELLOW} 5.${NC} 安装 Windows 10 LTSC 系统 (默认密码: $DEFAULT_PASS)"
    echo -e "${YELLOW} 6.${NC} 安装 aaPanel 面板 (AaronYES 破解版)"
    echo -e "${YELLOW} 7.${NC} 安装 aaPanel 面板 (官方正式版)"
    echo -e "${YELLOW} 8.${NC} 安装 Realm 端口转发工具"
    echo -e "${YELLOW} 9.${NC} 安装 ServerStatus 监控探针 (默认端口: $DEFAULT_PORT)"
    echo -e "${YELLOW} 10.${NC} 安装 Xray 代理服务 (233boy版)"
    echo -e "${YELLOW} 11.${NC} 安装 XrayR 后端对接脚本"
    echo -e "${BLUE}--------------------------------------------------${NC}"
    echo -e "${RED} 0.${NC} 退出脚本 (或连续两次回车退出)"
    echo -e "${BLUE}==================================================${NC}"
}

while true; do
    show_menu
    read -p "请输入对应数字进行操作: " choice
    
    if [[ -z "$choice" ]]; then
        ((empty_count++))
        [[ $empty_count -ge 2 ]] && exit 0
        continue
    else
        empty_count=0
    fi

    case $choice in
        1)
            wget -qO- bench.sh | bash
            read -p "按回车键继续..."
            ;;
        2)
            read -p "请输入 SSH 端口 (直接回车则不修改): " ssh_port
            if [[ -n "$ssh_port" && "$ssh_port" =~ ^[0-9]+$ ]]; then
                sed -i "s/^#\?Port .*/Port $ssh_port/" /etc/ssh/sshd_config
                if command -v ufw >/dev/null 2>&1; then ufw allow $ssh_port/tcp; fi
                systemctl restart ssh
                echo -e "${GREEN}端口已修改为 $ssh_port。后续请通过 ssh -p $ssh_port 连接。${NC}"
            else
                echo -e "${YELLOW}操作取消。${NC}"
            fi
            read -p "按回车键继续..."
            ;;
        3)
            bash <(curl -Lso- https://github.com/teddysun/across/raw/master/bbr.sh)
            ;;
        4)
            read -p "请输入登录密码 (回车默认: $DEFAULT_PASS): " dd_pass
            dd_pass=${dd_pass:-$DEFAULT_PASS}
            echo -e "${RED}确认信息：系统 Debian 11 | 用户 root | 密码 $dd_pass${NC}"
            echo -e "${YELLOW}系统将在 10 秒后开始安装，请及时保存密码信息...${NC}"
            sleep 10
            bash <(wget --no-check-certificate -qO- 'https://www.moeelf.com/attachment/LinuxShell/InstallNET.sh') -d 11 -v 64 -a -p "$dd_pass"
            ;;
        5)
            get_network_info
            read -p "请输入登录密码 (回车默认: $DEFAULT_PASS): " win_pass
            win_pass=${win_pass:-$DEFAULT_PASS}
            echo -e "${RED}确认信息：系统 Win10 | 用户 Administrator | 密码 $win_pass${NC}"
            echo -e "${YELLOW}系统将在 10 秒后开始安装，请及时保存密码信息...${NC}"
            sleep 10
            wget -qO- inst.sh | bash -s - -n $LOCAL_IP,$LOCAL_MASK,$LOCAL_GATEWAY -p "$win_pass" -t https://dl.lamp.sh/vhd/zh-cn_windows10_ltsc.xz
            ;;
        6)
            wget https://raw.githubusercontent.com/AaronYES/aaPanel/main/script/aapanel.sh -O aapanel.sh && chmod +x aapanel.sh && ./aapanel.sh
            echo -e "${GREEN}安装完成！后续管理面板快捷命令为: ${RED}bt${NC}"
            read -p "按回车键继续..."
            ;;
        7)
            URL=https://www.aapanel.com/script/install_panel_en.sh
            if [ -f /usr/bin/curl ];then curl -ksSO $URL ;else wget --no-check-certificate -O install_panel_en.sh $URL;fi
            bash install_panel_en.sh ipssl
            echo -e "${GREEN}安装完成！后续管理面板快捷命令为: ${RED}bt${NC}"
            exit 0
            ;;
        8)
            wget https://raw.githubusercontent.com/jinqians/realm/refs/heads/main/realm.sh && chmod +x realm.sh && ./realm.sh
            echo -e "${GREEN}安装完成！后续管理快捷命令为: ${RED}./realm.sh${NC}"
            read -p "按回车键继续..."
            ;;
        9)
            read -p "请输入探针访问端口 (回车默认: $DEFAULT_PORT): " s_port
            s_port=${s_port:-$DEFAULT_PORT}
            wget --no-check-certificate -qO ~/serverstatus-config.json https://raw.githubusercontent.com/cppla/ServerStatus/master/server/config.json && mkdir -p ~/serverstatus-monthtraffic
            docker run -d --restart=always --name=status -v ~/serverstatus-config.json:/ServerStatus/server/config.json -v ~/serverstatus-monthtraffic:/usr/share/nginx/html/json -p $s_port:80 -p 35601:35601 cppla/serverstatus:1.1.5
            echo -e "${GREEN}探针安装完成！请访问 http://IP:$s_port ${NC}"
            echo -e "${GREEN}后续管理命令: ${RED}docker ps / docker restart status${NC}"
            read -p "按回车键继续..."
            ;;
        10)
            bash <(wget -qO- -o- https://github.com/233boy/Xray/raw/main/install.sh)
            echo -e "${GREEN}安装完成！后续管理快捷命令为: ${RED}xray${NC}"
            read -p "按回车键继续..."
            ;;
        11)
            wget -N https://raw.githubusercontent.com/youzi3/XrayR-script/main/install.sh && bash install.sh
            echo -e "${GREEN}安装完成！后续管理快捷命令为: ${RED}xrayr${NC}"
            read -p "按回车键继续..."
            ;;
        0)
            exit 0
            ;;
        *)
            echo -e "${RED}选择无效。${NC}"
            sleep 1
            ;;
    esac
done
